# Pi-side configuration. Copy to .env on the Pi and fill in real values.

# Cloud ingest
INGEST_URL=http://your-ec2-public-ip:5001
INGEST_TOKEN=copy-from-server/ingest_api/.env-on-EC2
DEVICE_ID=pi-01

# Local SQLite buffer
BUFFER_DB_PATH=/home/pi/aquaponics_dashboard/readings.db

# Cadence
SAMPLE_EVERY_SEC=5
UPLOAD_EVERY_SEC=30
UPLOAD_BATCH_SIZE=100
RETAIN_UPLOADED_DAYS=7
