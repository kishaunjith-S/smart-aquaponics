# Database (RDS PostgreSQL)
DATABASE_URL=postgresql://app_writer:PASSWORD@your-rds-endpoint:5432/aquaponics
LSTM_READER_DATABASE_URL=postgresql://lstm_reader:PASSWORD@your-rds-endpoint:5432/aquaponics

# Auth
JWT_SECRET=generate-with-python-secrets-token-urlsafe-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Pi → EC2 ingest bearer token
INGEST_TOKEN=generate-with-python-secrets-token-urlsafe-32

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# App
APP_NAME=aquaponics-api
APP_ENV=development

# Gemini AI (chatbot tab) — get from https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza-your-key-here
